{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vibe Voice",
  "version": "0.1.0",
  "identifier": "com.vibeioice.vibeioice",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Vibe Voice",
        "width": 340,
        "height": 160,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
