{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vibe-voice",
  "version": "0.1.1",
  "identifier": "com.vibeioice.vibeioice",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Vibe Voice",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "resources": {
      "icons/tray-idle.png": "icons/tray-idle.png",
      "icons/tray-recording.png": "icons/tray-recording.png",
      "icons/tray-done.png": "icons/tray-done.png"
    }
  }
}
